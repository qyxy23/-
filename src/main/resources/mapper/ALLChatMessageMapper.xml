<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- namespace等于mapper接口类的全限定名,这样实现对应 -->
<mapper namespace="com.guanyu.haigui.mapper.ALLChatMessageMapper">


    <insert id="insertGroupUserMessage">
        insert into chat_messages(chat_type,chat_id,sender_type,sender_id,content,status,send_time,is_read)
        values(#{chatType},#{chatId},#{senderType},#{senderId},#{content},#{status},#{sendTime},#{isRead})
    </insert>
</mapper>
    